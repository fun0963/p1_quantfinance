# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Alpaca (paper trading + data) ---
# Get keys at https://app.alpaca.markets/ (use PAPER keys for now)
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_PAPER=true                       # true = paper trading endpoint

# --- Runtime ---
ENV=dev                                 # dev | prod
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
DATA_DIR=./data
LOG_DIR=./logs

# --- Storage ---
STORAGE_BACKEND=parquet                 # parquet (local cache) | timescale (TimescaleDB)
# Used only when STORAGE_BACKEND=timescale. Matches docker-compose's timescaledb service.
TIMESCALE_DSN=postgresql://quant:quant@localhost:5432/quant
